#!/bin/sh
# agent-tasks worktree post-remove フック (Firebase テンプレ)。
# done で `git worktree remove` する直前に、worktree がまだ在るうちに 1 度実行される
# (cwd = その worktree)。post-create と対。
#
# Firebase テンプレの post-create が作るもの (.env.local / emulator-data/ / node_modules)
# はすべて worktree 内に閉じているので、worktree を消せば一緒に消える = 通常は後始末不要。
# このフックは「外部に残る副作用を足したとき」の置き場として用意してある。
#
# 渡される env: AGENT_TASKS_WORKTREE / AGENT_TASKS_MAIN / AGENT_TASKS_PROJECT
# 後始末は best-effort なので set -e はしない。

WT_NAME=$(basename "${AGENT_TASKS_WORKTREE:-$PWD}")

# 例: emulator のエクスポートデータを別ディレクトリに置いている / 外部リソースを
# worktree ごとに確保している場合だけ、ここで後始末する。既定では何もしない。
echo "post-remove (firebase): $WT_NAME — worktree 内で完結する副作用のみのため後始末なし"
